{
  "mcpServers": {
    "notion": {
      "url": "https://mcp.notion.com/mcp"
    },
    "dropbox": {
      "url": "https://mcp.dropbox.com/mcp"
    },
    "openrouter": {
      "url": "https://mcp.openrouter.ai/mcp"
    },
    "notionApi": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_TOKEN": "${env:NOTION_TOKEN}"
      }
    }
  }
}
